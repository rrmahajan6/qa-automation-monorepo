<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="Automation Test Suite" parallel="methods" thread-count="1" data-provider-thread-count="4">
    <!-- Suite Configuration -->
    
    <!-- Listeners Configuration -->
    <listeners>
        <listener class-name="framework.listeners.TestListener"/>
    </listeners>

    <!-- Test Configuration - Purchase Group Only -->
    <test name="Purchase Tests" enabled="true">
        <groups>
            <run>
                <include name="purchase"/>
            </run>
        </groups>
        <classes>
            <class name="tests.LoginTests"></class>
            <class name="tests.PurchaseProduct"></class>
        </classes>
    </test>

    <!-- 
    Additional Suite Examples:

    <test name="Dashboard Tests" enabled="false">
        <classes>
            <class name="tests.DashboardTests"/>
        </classes>
    </test>

    <test name="Profile Tests" enabled="false">
        <classes>
            <class name="tests.ProfileTests"/>
        </classes>
    </test>

    Example for running specific methods:
    <test name="Smoke Tests" enabled="false">
        <classes>
            <class name="tests.LoginTests">
                <methods>
                    <include name="testLoginPageLoads"/>
                    <include name="testSuccessfulLogin"/>
                </methods>
            </class>
        </classes>
    </test>

    Example for excluding specific methods:
    <test name="All Except Smoke" enabled="false">
        <classes>
            <class name="tests.LoginTests">
                <methods>
                    <exclude name="testLoginPageLoads"/>
                    <exclude name="testSuccessfulLogin"/>
                </methods>
            </class>
        </classes>
    </test>
    -->
</suite>
