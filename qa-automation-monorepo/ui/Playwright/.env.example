# Environment Variables Template
# Copy this to .env and fill in your values

# Environment (dev, qa, staging, prod)
ENV=qa

# Browser Settings
HEADLESS=true
DEBUG=false

# ===================================
# Azure Key Vault Configuration
# ===================================
# Key Vault name (required for Azure Key Vault integration)
AZURE_KEYVAULT_NAME=your-keyvault-name

# Authentication Method 1: Service Principal (for local development and CI/CD)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Authentication Method 2: Managed Identity (for Azure-hosted apps)
# Uncomment the line below when using Managed Identity
# USE_MANAGED_IDENTITY=true

# Database SSL Configuration (set to true for Azure SQL)
DB_SSL=true

# ===================================
# Database Configuration (Legacy - if not using Key Vault)
# ===================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=testdb
DB_USER=testuser
DB_PASSWORD=password

# API Settings (future use)
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here

# Authentication (if using env vars instead of config files)
TEST_USERNAME=testuser@example.com
TEST_PASSWORD=Test@123

# Timeouts (milliseconds)
DEFAULT_TIMEOUT=30000
PAGE_LOAD_TIMEOUT=60000

# CI/CD Settings
CI=false
